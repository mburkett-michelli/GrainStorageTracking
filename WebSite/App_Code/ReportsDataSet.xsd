                <SelectCommand>
                  <DbCommand CommandType="Text" ModifiedByUser="true">
                    <CommandText>SELECT        Ticket.*, Shipping.Customer, Shipping.Bin, Shipping.Variety, Shipping.Lot, Shipping.Bush_Ticket, Shipping.ID, Weights.In_Weight, Weights.Out_Weight, 
                         CASE WHEN In_Weight &gt; Out_Weight THEN In_Weight ELSE Out_Weight END AS Gross, CASE WHEN Out_Weight &gt; In_Weight THEN In_Weight ELSE Out_Weight END AS Tare, 
                         ABS(Weights.In_Weight - Weights.Out_Weight) AS Net
FROM            Ticket INNER JOIN
                         Shipping ON Ticket.Ticket = Shipping.Ticket INNER JOIN
                             (SELECT        Ticket, SUM(In_Weight) AS In_Weight, SUM(Out_Weight) AS Out_Weight
                               FROM            Ticket_Weights
                               GROUP BY Ticket) AS Weights ON Ticket.Ticket = Weights.Ticket</CommandText>
