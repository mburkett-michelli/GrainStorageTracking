                         CASE WHEN Out_Weight &gt; In_Weight THEN In_Weight ELSE Out_Weight END AS Tare, ABS(Weights.In_Weight - Weights.Out_Weight) AS Net
FROM            Ticket INNER JOIN
                         Shipping ON Ticket.Ticket = Shipping.Ticket INNER JOIN
                             (SELECT        Ticket, SUM(In_Weight) AS In_Weight, SUM(Out_Weight) AS Out_Weight
                               FROM            Ticket_Weights
                               GROUP BY Ticket) AS Weights ON Ticket.Ticket = Weights.Ticket
